{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./lib",
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "NodeNext",
        "types": ["node"],
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "declaration": true
    },
    "include": ["./src/**/*.ts"],
    "references": [
        {"path": "./src/core"},
        {"path": "./src/editor"},
        {"path": "./src/identify"},
        {"path": "./src/uc"},
        {"path": "./src/vls"},
    ]
}