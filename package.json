{
    "name": "lifeweb",
    "version": "1.0.0",
    "description": "Cellular automata simulation library",
    "license": "MIT",
    "author": "speedydelete",
    "main": "src/index.ts",
    "type": "module",
    "files": [
        "src",
        "lib"
    ],
    "devDependencies": {
        "@types/node": "^24.12.2",
        "typescript": "^5.9.3"
    },
    "optionalDependencies": {
        "@minify-html/node": "^0.18.1",
        "esbuild": "^0.28.0"
    },
    "allowScripts": {
        "esbuild@0.28.1": true
    },
    "homepage": "https://github.com/speedydelete/lifeweb",
    "wrecked_vls": {
        "html": "src/vls/test.html",
        "showErrors": true,
        "imports": {
            "./index.js": "src/vls/index.ts",
            "./index.c": "src/vls/index.c"
        }
    },
    "wrecked_identify": {
        "html": "src/identify/index.html",
        "showErrors": true,
        "files": {
            "<script type=\"module\" src=\"index.js\"></script>": "src/identify/index.ts"
        }
    },
    "wrecked_editor": {
        "html": "src/editor/index.html",
        "files": {
            "<script type=\"module\" src=\"index.js\"></script>": "src/editor/index.ts"
        }
    },
    "wrecked": {
        "html": "src/vls/test.html",
        "showErrors": true,
        "imports": {
            "./index.js": "src/vls/index.ts",
            "./index.c": "src/vls/index.c"
        }
    }
}
